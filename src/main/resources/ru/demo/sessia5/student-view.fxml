<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.demo.sessia5.StudentController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <top>
                <FlowPane BorderPane.alignment="CENTER">
                    <children>
                        <TextField fx:id="searchFullNameField" prefHeight="25.0" prefWidth="214.0" promptText="Поиск по ФИО">
                            <FlowPane.margin>
                                <Insets left="10.0" />
                            </FlowPane.margin>
                        </TextField>
                        <Label text="Факультет">
                            <FlowPane.margin>
                                <Insets left="10.0" />
                            </FlowPane.margin>
                        </Label>
                        <ComboBox fx:id="facultyFilterComboBox" prefWidth="150.0" />
                        <ComboBox fx:id="sortComboBox" prefHeight="25.0" prefWidth="193.0" promptText="сортировать по номеру специальности" />
                    </children>
                </FlowPane>
            </top>
            <center>
                <TableView fx:id="tableView" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                    <columns>
                        <TableColumn fx:id="numberpp" prefWidth="138.0" text="Номер п.п" />
                        <TableColumn fx:id="specialtyNumber" prefWidth="185.0" text="Номер специальности" />
                        <TableColumn fx:id="fullName" prefWidth="193.0" text="ФИО" />
                        <TableColumn fx:id="faculty" prefWidth="193.0" text="Факультет" />
                    </columns>
                </TableView>
            </center>
            <bottom>
                <ToolBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                    <items>
                        <Button mnemonicParsing="false" onAction="#onAddClick" text="Добавить" />
                        <Button mnemonicParsing="false" onAction="#onRemoveClick" text="Удалить" />
                        <Button mnemonicParsing="false" onAction="#onUpdateClick" text="Изменить" />
                    </items>
                </ToolBar>
            </bottom>
        </BorderPane>
    </children>
</AnchorPane>